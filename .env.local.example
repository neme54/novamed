# Database
DATABASE_URL=postgresql://user:password@localhost:5432/novamed

# NextAuth
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=your-secret-here

# WhatsApp (Nigeria: 234 + number without leading 0)
NEXT_PUBLIC_WHATSAPP_NUMBER=2348108217791

# Email (Resend recommended)
RESEND_API_KEY=
EMAIL_FROM=noreply@novamedpharma.com
BOOKING_NOTIFICATION_EMAIL=bookings@novamedpharma.com
ORDER_NOTIFICATION_EMAIL=orders@novamedpharma.com

# SMS (Termii for Nigeria)
TERMII_API_KEY=
TERMII_SENDER_ID=NovaMed

# File Storage (Cloudinary)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Maps: Contact & About use Leaflet/OpenStreetMap (no key needed)
# NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=

# Site
NEXT_PUBLIC_SITE_URL=https://novamedpharma.com
NEXT_PUBLIC_SITE_NAME=NovaMed Pharmaceuticals Ltd.

# Legacy / optional
